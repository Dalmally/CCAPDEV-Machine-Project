<div class="container">
    <div class="profile-header">
        <div id="icon-section">
            <div id="icon-div">
                <img src="{{user.avatar_url}}" alt="User avatar" id="avatar">
            </div>
        </div>

        <div id="details-section">
            {{#if user}}
            <div id="username">
                <h2>{{user.username}}</h2>
                {{#if isOwnProfile}}
                <a href="/profile/edit" class="edit-btn">Edit Profile</a>
                {{/if}}
            </div>
            <div id="bio">
                <p>{{user.bio}}</p>
            </div>
            <div id="badge">
                <p>{{user.badge}}</p>
            </div>
            {{else if admin}}
            <div id="username">
                <h2>Admin: {{admin.email}}</h2>
            </div>
            {{else}}
            <p>User not found.</p>
            {{/if}}
        </div>
    </div>
</div>

<div class="posts-container">
    <h2>Recent Posts</h2>
    <div id="posts">
        {{#if user.posts.length}}
        {{#each user.posts}}
        <article class="post-card">
            <div class="post-meta">Posted by {{../user.username}} • {{date}}</div>
            <h3>{{title}}</h3>
            <p>{{contentPreview}}</p>
            <a href="/post/{{post_id}}" class="read-more">View Full Thread →</a>
        </article>
        {{/each}}
        {{else}}
        <p>No posts yet.</p>
        {{/if}}
    </div>
</div>
