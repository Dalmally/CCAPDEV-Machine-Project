<div class="search-container">

    <div class="search-header">
        <h1 class="search-title">
            Tech Mod <span class="accent">Forum</span>
        </h1>
    </div>

    <div class="search-card">
        <div class="search-input-group">
            <input type="text" placeholder="Search topics..." class="search-input">
            <button type="submit" class="search-btn">Search</button>
        </div>
    </div>

    {{#if results.length}}
    <div class="search-results">
        <h2>Search Results</h2>
        {{#each results}}
        <div class="result-item">
            <h3>{{title}}</h3>
            <p>{{contentPreview}}</p>
            <a href="viewpost">View Post</a>
        </div>
        {{/each}}
    </div>
    {{else}}
    <p>No results found. Try a different search term.</p>
    {{/if}}

    <div class="categories-search-card">
        <div class="categories-search-header">
            <h2>Explore Forum Categoriess</h2>
        </div>

        <div class="categories-search-links">
            <a href="viewcategory">Electronic Schemas</a> 
            <a href="viewcategory">Hardware Repair & Teardown</a> 
            <a href="viewcategory">Firmware Mods</a> 
            <a href="viewcategory">Mobile Development</a> 
            <a href="viewcategory">Sideloading</a> 
        </div>
    </div>

</div>
