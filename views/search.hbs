<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Tech Mod Forum - Search</title>
    <link rel="stylesheet" href="styles/main.css">
    <link rel="stylesheet" href="styles/header.css">
    <link rel="stylesheet" href="styles/categories.css">
    <link rel="stylesheet" href="styles/search.css">
    
</head>

<body class="search-body">

    <!--Sidebar-->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <aside class="sidebar" id="sidebar">
        <h2 class="sidebar-logo">Categories</h2>
        <button class="close-sidebar" id="closeSidebarBtn">✕</button>

        <nav class="sidebar-nav">
            <ul class="menu">
                <li class="menu-category">
                    Electronic Schemas
                    <ul>
                        <li><a href="viewcategory.html">Android</a></li>
                        <li><a href="viewcategory.html">iPhone</a></li>
                        <li><a href="viewcategory.html">iPad</a></li>
                        <li><a href="viewcategory.html">Xbox</a></li>
                        <li><a href="viewcategory.html">Playstation</a></li>
                    </ul>
                </li>

            <li class="menu-category">
                Hardware Repair & Teardown
                <ul>
                    <li><a href="viewcategory.html">Console</a></li>
                    <li><a href="viewcategory.html">Android</a></li>
                    <li><a href="viewcategory.html">Apple</a></li>
                    <li><a href="viewcategory.html">Nintendo</a></li>
                    <li><a href="viewcategory.html">General Electronics</a></li>
                </ul>
            </li>

            <li class="menu-category">
                Firmware Mods
                <ul>
                    <li><a href="viewcategory.html">Console</a></li>
                    <li><a href="viewcategory.html">Android</a></li>
                    <li><a href="viewcategory.html">Nintendo</a></li>
                    <li><a href="viewcategory.html">General Electronics</a></li>
                </ul>
            </li>

            <li class="menu-category">
                Mobile Development
                <ul>
                    <li><a href="viewcategory.html">Android</a></li>
                    <li><a href="viewcategory.html">iOS / iPadOS</a></li>
                </ul>
            </li>

            <li class="menu-category">
                Sideloading
                <ul>
                    <li><a href="viewcategory.html">iOS</a></li>
                    <li><a href="viewcategory.html">iPadOS</a></li>
                </ul>
            </li>

            </ul>
        </nav>
    </aside>

    <!--Header-->

    <header class="header">
        <a href="index.html" class="logo">FORUM</a>

        {{nav}}

        <div class="auth-buttons">
            <a href="login.html" class="login-btn">Log in</a>
            <a href="registration.html" class="register-btn">Register</a>
        </div>
    </header>

    <script src="scripts/categories.js"></script>

<div class="search-container">

    <div class="search-header">
        <h1 class="search-title">
            Tech Mod <span class="accent">Forum</span>
        </h1>
    </div>

    <div class="search-card">
        <div class="search-input-group">
            <input type="text" placeholder="Search topics..." class="search-input">
            <button type="submit" class="search-btn">Search</button>
        </div>
    </div>

    {{#if results.length}}
    <div class="search-results">
        <h2>Search Results</h2>
        {{#each results}}
        <div class="result-item">
            <h3>{{title}}</h3>
            <p>{{contentPreview}}</p>
            <a href="viewpost.html">View Post</a>
        </div>
        {{/each}}
    </div>
    {{else}}
    <p>No results found. Try a different search term.</p>
    {{/if}}

    <div class="categories-search-card">
        <div class="categories-search-header">
            <h2>Explore Forum Categoriess</h2>
        </div>

        <div class="categories-search-links">
            <a href="viewcategory.html">Electronic Schemas</a> 
            <a href="viewcategory.html">Hardware Repair & Teardown</a> 
            <a href="viewcategory.html">Firmware Mods</a> 
            <a href="viewcategory.html">Mobile Development</a> 
            <a href="viewcategory.html">Sideloading</a> 
        </div>
    </div>

</div>

</body>
</html>
