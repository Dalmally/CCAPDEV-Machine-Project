<main class="feed-container">
    {{#if category}}
    <div class="feed-header">
        <h1>Posts in: {{category.name}}</h1>
        <p>{{category.description}}</p>
    </div>
    {{else}}
    <p>Category not found.</p>
    {{/if}}

    {{#if posts.length}}
    {{#each posts}}
    <article class="post-card">
        <div class="post-meta">Posted by {{author}} at {{date}}</div>
        <h3>{{title}}</h3>
        <p>{{contentPreview}}</p>
        <a href="/post/{{id}}" class="read-more">View Full Thread →</a>
    </article>
    {{/each}}
    {{else}}
    <p>No posts in this category yet.</p>
    {{/if}}
</main>