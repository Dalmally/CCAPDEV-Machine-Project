<div class="container">
    <h1>Create a New Post</h1>
    <form action="/post/create" method="POST" id="createpostForm">
        <div id="errorMessages" style="color: red; display: none;"></div>
        
        <div class="form-group">
            <label for="post-title">Post Title</label>
            <input type="text" id="post-title" name="title" placeholder="e.g. How to flash custom BIOS" required>
        </div>

        <div class="form-group">
            <label for="category">Select Category</label>
            <select id="category" name="category_id" required>
                <option value="" disabled selected>-- Choose a category --</option>
                {{#each categoryGroups}}
                <optgroup label="{{parent}}">
                    {{#each subs}}
                    <option value="{{id}}">{{name}}</option>
                    {{/each}}
                </optgroup>
                {{/each}}
            </select>
        </div>

        <div class="form-group">
            <label for="content">Post Content</label>
            <textarea id="content" name="content" placeholder="Describe your mod or ask a question..." required></textarea>
        </div>

        <button type="submit" class="btn-submit">Publish to Forum</button>
    </form>
    
    <a href="home" class="back-link">← Back to Home</a>
</div>

</body>
</html>