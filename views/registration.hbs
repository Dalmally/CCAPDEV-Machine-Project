<div class="reg-container">

    <div class="reg-header">
        <h1 class="reg-title">
            Create <span class="reg-title-accent">Account</span>
        </h1>
        <p class="reg-subtitle">Join Tech Mod Forum</p>
    </div>

    <div class="reg-card">
        <div class="reg-top-bar"></div>
        <div class="reg-card-body">

            <form action="/register" method="post" id="registerForm">

                <div id="errorMessages" style="color: red; display: none;"></div>

                <div class="reg-field-group">
                    <label class="reg-label" for="email">Email</label>
                    <input class="reg-input" type="text" name="email" id="email" required>
                </div>

                <div class="reg-field-group">
                    <label class="reg-label" for="username">Username</label>
                    <input class="reg-input" type="text" name="username" id="username" required>
                </div>

                <div class="reg-field-group">
                    <label class="reg-label" for="password">Password</label>
                    <input class="reg-input" type="password" name="password" id="password" required>
                </div>

                <div class="reg-field-group">
                    <label class="reg-label" for="repeat-password">Repeat Password</label>
                    <input class="reg-input" type="password" name="repeat-password" id="repeat-password" required>
                </div>

                <div class="reg-divider"></div>

                <p class="reg-terms">
                    By creating an account you agree to the terms and conditions.
                </p>

                <button type="submit" class="reg-button">Register</button>

            </form>
        </div>

        <div class="reg-footer">
            <p class="reg-footer-text">
                Already have an account?
                <a href="/login" class="reg-footer-link">Sign In</a>
            </p>

            <p class="reg-footer-text">
                <a href="/" class="reg-footer-link">Back to Index</a>
            </p>
        </div>

    </div>

    <p class="reg-bottom-note">Tech Mod Forum © 2026</p>

{{#if showPopup}}
<div id="errorPopup" class="popup-overlay">
    <div class="popup-box">
        <h2>Registration Error</h2>
        <p>{{error}}</p>
        <button onclick="closePopup()">OK</button>
    </div>
</div>
{{/if}}

<script>
    function closePopup() {
        const popup = document.getElementById('errorPopup');
        if (popup) {
            popup.style.display = 'none';
        }
    }

    window.onload = function () {
        const popup = document.getElementById('errorPopup');
        if (popup) {
            popup.style.display = 'flex';
        }
    }
</script>

</div>
