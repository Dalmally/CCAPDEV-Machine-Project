<div class="container">
    {{!-- Form for updating Profile --}}
    <form action="/profile/edit" id="profileform" method="POST" enctype="multipart/form-data">
        <div id="header">
            <h2>Edit Profile</h2>
        </div>

        <div id="avatarsection">
            {{!-- Avatar upload --}}
            <input type="file" name="avatar" id="avatarInput" accept="image/*" hidden>
            <div class="avatar-container" onclick="document.getElementById('avatarInput').click()">
                <img src="{{user.avatarUrl}}" alt="Current Avatar" class="avatar">
                <div class="overlay">
                    <span class="overlay-text">Change Avatar</span>
                </div>
            </div>
        </div>

        <div class="details">
            <label for="username">Username</label>
            <input type="text" name="username" id="username" value="{{user.username}}" placeholder="Enter new username">
        </div>

        <div class="details">
            <label for="bio">Bio</label>
            <textarea name="bio" id="bio" placeholder="Tell us about yourself...">{{user.bio}}</textarea>
        </div>

        <div id="actions">
            <a href="/profile" class="button cancel-btn">Cancel</a>
            <button type="submit" class="button save-btn">Save Changes</button>
        </div>
    </form>

    <hr>

    {{!-- View Own Posts Section --}}
    <div class="user-posts-section">
        <h3>My Posts</h3>
        <div class="posts-grid">
            {{#if posts.length}}
                {{#each posts}}
                    <div class="post-card">
                        <h4><a href="/post/{{this.post_id}}">{{this.title}}</a></h4>
                        <p>{{this.contentPreview}}</p>
                        <span class="post-date">{{this.date}}</span>
                    </div>
                {{/each}}
            {{else}}
                <p>You haven't posted anything yet.</p>
            {{/if}}
        </div>
    </div>
</div>