<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles/main.css">
    <link rel="stylesheet" href="styles/editprofile.css">
    <link rel="stylesheet" href="styles/header.css">
    <link rel="stylesheet" href="styles/categories.css">
    <title>Edit Profile</title>
</head>
<body>
    <!--Sidebar-->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <aside class="sidebar" id="sidebar">
        <h2 class="sidebar-logo">Categories</h2>
        <button class="close-sidebar" id="closeSidebarBtn">✕</button>

        <nav class="sidebar-nav">
            <ul class="menu">
                <li class="menu-category">
                    Electronic Schemas
                    <ul>
                        <li><a href="viewcategory">Android</a></li>
                        <li><a href="viewcategory">iPhone</a></li>
                        <li><a href="viewcategory">iPad</a></li>
                        <li><a href="viewcategory">Xbox</a></li>
                        <li><a href="viewcategory">Playstation</a></li>
                    </ul>
                </li>

            <li class="menu-category">
                Hardware Repair & Teardown
                <ul>
                    <li><a href="viewcategory">Console</a></li>
                    <li><a href="viewcategory">Android</a></li>
                    <li><a href="viewcategory">Apple</a></li>
                    <li><a href="viewcategory">Nintendo</a></li>
                    <li><a href="viewcategory">General Electronics</a></li>
                </ul>
            </li>

            <li class="menu-category">
                Firmware Mods
                <ul>
                    <li><a href="viewcategory">Console</a></li>
                    <li><a href="viewcategory">Android</a></li>
                    <li><a href="viewcategory">Nintendo</a></li>
                    <li><a href="viewcategory">General Electronics</a></li>
                </ul>
            </li>

            <li class="menu-category">
                Mobile Development
                <ul>
                    <li><a href="viewcategory">Android</a></li>
                    <li><a href="viewcategory">iOS / iPadOS</a></li>
                </ul>
            </li>

            <li class="menu-category">
                Sideloading
                <ul>
                    <li><a href="viewcategory">iOS</a></li>
                    <li><a href="viewcategory">iPadOS</a></li>
                </ul>
            </li>

            </ul>
        </nav>
    </aside>

    <!--Header-->

    <header class="header">
        <a href="index" class="logo">FORUM</a>

        {{nav}}

        <div class="auth-buttons">
            <a href="login" class="login-btn">Log in</a>
            <a href="registration" class="register-btn">Register</a>
        </div>
    </header>

    <script src="scripts/categories.js"></script>
    <div class="container">
        <form action="home" id="profileform" method="GET">
            <div id="errorMessages" style="color: red; display: none;"></div>
            
            <div id="header">
                <h2>Edit Profile</h2>
            </div>

            <br>
            
            <div id="avatarsection">
                <input type="file" id="avatarInput" accept="image/*" hidden>
                
                <div class="avatar" onclick="document.getElementById(avatarInput).click()">
                    <img src="public/default-avatar.jpg" alt="Current Avatar" class="avatar">
                    <div class="overlay">
                        <span class="overlay-text">Change Avatar</span>
                    </div>
                </div>
            </div>

            <br><br>

            <div id="details">
                <label for="username">Username</label>
                <!--Placeholders will be replaced with the -->
                <input type="text" id="username" placeholder="Enter new username">
            </div>
            <br><br>

            <div id="details">
                <label for="bio">Bio</label>
                <input type="text" id="bio" placeholder="Enter new bio">
            </div>

            <br><br>
            
            <div id="actions">
                <button type="button" class="button">Cancel</button>
                <button type="submit" class="button">Save Changes</button>
            </div>
        </form>
    </div>
</body>
<script src="scripts/validation.js"></script>
</html>